{
  "expo": {
    "name": "EnviroGuard",
    "slug": "envro-guard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#059669",
      "resizeMode": "contain",
      "image": "./assets/splash-icon.png"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow EnviroGuard to access your photos to attach hazard report images.",
        "NSCameraUsageDescription": "Allow EnviroGuard to access your camera to take hazard photos.",
        "NSLocationWhenInUseUsageDescription": "Allow EnviroGuard to access your location to pinpoint hazard reports."
      }
    },
    "android": {
      "adaptiveIcon": {
"backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.buzzbrain.envroguard"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-image-picker",
      "expo-location",
      [
        "expo-notifications",
        {
          "color": "#059669"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "badeb40f-d509-4d0f-8bc3-f545472d1e73"
      }
    }
  }
}
