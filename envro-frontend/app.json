{
  "expo": {
    "name": "EnviroGuard",
    "slug": "envro-guard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#059669",
      "resizeMode": "contain",
      "image": "./assets/splash-icon.png"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow EnviroGuard to access your photos to attach hazard report images.",
        "NSCameraUsageDescription": "Allow EnviroGuard to access your camera to take hazard photos.",
        "NSLocationWhenInUseUsageDescription": "Allow EnviroGuard to access your location to pinpoint hazard reports."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#059669",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-image-picker",
      "expo-location",
      [
        "expo-notifications",
        {
          "color": "#059669"
        }
      ]
    ]
  }
}
