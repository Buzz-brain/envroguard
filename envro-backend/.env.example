# Environment Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/envro-guard

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_strong_secret
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=envro-guard

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_school_email@domain.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM="EnviroGuard Alert System <noreply@domain.com>"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=debug
